# Public site URL
NEXT_PUBLIC_SITE_URL=https://www.iamnobody.live

# Supabase Image Studio
# Get these from Supabase Dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Server-only. Never expose this key in browser code or commit it to Git.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# OpenAI Image Studio — all values below are required and server-only
# The book knowledge is embedded in lib/nobody/bookCreativeContext.ts.
# No PDF, Files API, Vector Store, or book-specific environment variable is required.
OPENAI_API_KEY=your_openai_api_key
OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21
OPENAI_REVIEW_MODEL=gpt-5.6-luna
OPENAI_PLANNER_MODEL=gpt-5.6-luna

# Shopify storefront
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token
SHOPIFY_API_VERSION=2025-10

# Join/newsletter notification email
# Use the SMTP credentials shown by Register.it for the mailbox/domain.
SMTP_HOST=authsmtp.securemail.pro
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=andreamagelli@iamnobody.live
SMTP_PASS=your_register_it_smtp_password
MAIL_FROM="I AM NOBODY <andreamagelli@iamnobody.live>"
AUTHOR_JOIN_RECIPIENT=andreamagelli@iamnobody.live
JOIN_NOTIFICATION_SUBJECT=New I AM NOBODY join request
# Daily artwork automation — server-only.
# Use a random value of at least 32 characters. Vercel sends it to the cron route.
CRON_SECRET=replace_with_a_random_secret_of_at_least_32_characters
